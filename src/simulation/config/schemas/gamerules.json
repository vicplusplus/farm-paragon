{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "title": "GameRules",
    "type": "object",
    "properties": {
        "startingState": {
            "$ref": "./gamestate.json"
        },
        "timePerEco": {
            "type": "number"
        },
        "bloonQueueSize": {
            "type": "number"
        },
        "availableTowers": {
            "type": "array",
            "items": {
                "$ref": "./tower.json"
            }
        },
        "availableBloons": {
            "type": "array",
            "items": {
                "$ref": "./bloon.json"
            }
        },
        "rounds": {
            "type": "array",
            "items": {
                "$ref": "./round.json"
            }
        },
        "sellMultiplier": {
            "type": "number"
        }
    },
    "required": [
        "startingState",
        "timePerEco",
        "bloonQueueSize",
        "availableTowers",
        "availableBloons",
        "rounds",
        "sellMultiplier"
    ]
}